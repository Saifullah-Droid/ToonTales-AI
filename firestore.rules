rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && incoming().uid == userId
        && incoming().email is string
        && incoming().createdAt == request.time;
      allow update: if isOwner(userId)
        && incoming().uid == existing().uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    // --- Stories ---
    match /stories/{storyId} {
      function isValidStory(data) {
        return data.userId == request.auth.uid
          && data.title is string && data.title.size() <= 200
          && data.storyText is string && data.storyText.size() <= 10000
          && data.childAge is string
          && data.createdAt == request.time;
      }

      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidStory(incoming());
      allow update: if isSignedIn() 
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['imageUrls'])
        && incoming().imageUrls is list;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
